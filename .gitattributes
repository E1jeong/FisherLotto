# Normalize line endings regardless of which tool/agent/OS writes a file.
# eol=lf takes precedence over core.autocrlf for matched paths.
* text=auto eol=lf

*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.pro text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
gradlew text eol=lf
gradlew.bat text eol=crlf

*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ttf binary
*.otf binary
*.jar binary
*.keystore binary
*.jks binary
